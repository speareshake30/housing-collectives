# Database Configuration
DB_USER=hcollective
DB_PASSWORD=your_secure_password_here
DB_NAME=housing_collectives
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Backend Configuration
NODE_ENV=development
API_PORT=3001
WS_PORT=3002
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend Configuration
FRONTEND_PORT=3000

# Email (Development)
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# AWS S3 (for file uploads in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-central-1

# Mapbox/Google Maps (for map features)
MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# Cloud Provider (deployment)
CLOUD_PROVIDER=hcloud
HCLOUD_TOKEN=

# Domain and SSL
DOMAIN=localhost
SSL_EMAIL=
